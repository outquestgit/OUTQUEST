# ---- Supabase ----
# Project URL + anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — SERVER ONLY. Never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- reCAPTCHA v3 ----
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ---- Brevo (transactional email + lists) ----
BREVO_API_KEY=your-brevo-api-key
BREVO_LIST_ID=0
# Where new-lead notifications go (the platform owner/admin inbox).
LEAD_NOTIFY_EMAIL=admin@example.com
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=GetSetGo

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Maintenance / kill switch ----
# Set to `true` to take the ENTIRE site offline (public pages, admin, and API)
# with an HTTP 503 "temporarily unavailable" page. Leave blank / remove / set to
# `false` to keep the site live. Requires a redeploy/restart to take effect.
MAINTENANCE_MODE=false
